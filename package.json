{
  "name": "bunbooru",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*",
    "plugins/*"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "NODE_ENV=test bun test",
    "dev": "bun run --cwd apps/api dev",
    "build:api": "bun run apps/api/build.ts",
    "docker:build": "docker build -t bunbooru:latest .",
    "services:up": "docker compose up -d",
    "services:up:redis": "docker compose --profile redis up -d",
    "services:down": "docker compose down",
    "services:logs": "docker compose logs -f"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^6"
  }
}
