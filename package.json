{
  "name": "bunbooru",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*",
    "plugins/*"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit && tsc --noEmit -p apps/web/tsconfig.json",
    "test": "NODE_ENV=test bun test",
    "dev": "bun run --cwd apps/api dev",
    "dev:web": "bun run --cwd apps/web dev",
    "build:api": "bun run apps/api/build.ts",
    "docker:build": "docker build -t bunbooru:latest .",
    "services:up": "docker compose up -d",
    "services:up:redis": "docker compose --profile redis up -d",
    "services:down": "docker compose down",
    "services:logs": "docker compose logs -f",
    "lint:boundaries": "depcruise apps packages plugins"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "dependency-cruiser": "^18.0.0",
    "typescript": "^6"
  }
}
