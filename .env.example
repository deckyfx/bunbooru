# Copy to .env and adjust. `.env` is git-ignored.

# Environment
NODE_ENV=development

# PostgreSQL (required) — consumed by docker-compose and the app
POSTGRES_USER=bunbooru
POSTGRES_PASSWORD=bunbooru
POSTGRES_DB=bunbooru
POSTGRES_PORT=5432
DATABASE_URL=postgres://bunbooru:bunbooru@localhost:5432/bunbooru

# Integration tests (optional) — opt-in URL for the destructive integration
# suite, which TRUNCATEs between cases. Kept separate from DATABASE_URL so the
# tests can never wipe a real database; unset → those tests skip. Point it at a
# THROWAWAY database only.
# TEST_DATABASE_URL=postgres://bunbooru:bunbooru@localhost:5432/bunbooru_test

# Redis (optional accelerator) — only when running the `redis` compose profile
REDIS_PORT=6379
# REDIS_URL=redis://localhost:6379
