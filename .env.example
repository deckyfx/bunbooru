# Copy to .env and adjust. `.env` is git-ignored.

# Environment
NODE_ENV=development

# PostgreSQL (required) — consumed by docker-compose and the app
POSTGRES_USER=bunbooru
POSTGRES_PASSWORD=bunbooru
POSTGRES_DB=bunbooru
POSTGRES_PORT=5432
DATABASE_URL=postgres://bunbooru:bunbooru@localhost:5432/bunbooru

# Integration tests (optional) — opt-in URL for the destructive integration
# suite, which TRUNCATEs between cases. Kept separate from DATABASE_URL so the
# tests can never wipe a real database; unset → those tests skip. Point it at a
# THROWAWAY database only.
# TEST_DATABASE_URL=postgres://bunbooru:bunbooru@localhost:5432/bunbooru_test

# Redis (optional accelerator) — only when running the `redis` compose profile
REDIS_PORT=6379
# REDIS_URL=redis://localhost:6379

# Uploads & storage (all optional; sensible defaults shown)
# STORAGE_ROOT=./data/storage              # where asset blobs live (required in production)
# MAX_UPLOAD_BYTES=104857600               # one-shot POST /assets cap (<= 2 GiB request body); default 100 MiB
# MAX_RESUMABLE_UPLOAD_BYTES=10737418240   # resumable cap; chunked, so may exceed 2 GiB; default 10 GiB
# UPLOAD_GC_INTERVAL_MS=900000             # sweep expired upload sessions; default 15 min, 0 disables
# ASSET_ORPHAN_GC_INTERVAL_MS=86400000     # sweep orphaned asset blobs (full scan); default 24 h, 0 disables

# Auth (all optional; sensible defaults shown)
# SESSION_EXPIRY_MS=2592000000             # login-session lifetime (cookie Max-Age + DB expiry); default 30 days
# SESSION_GC_INTERVAL_MS=3600000           # sweep expired login sessions; default 1 h, 0 disables
# TRUST_PROXY=false                        # trust X-Forwarded-For for the rate-limit client IP; enable ONLY behind a proxy that sets it

# Runtime settings note: the upload caps (MAX_UPLOAD_BYTES / MAX_RESUMABLE_UPLOAD_BYTES)
# above are DEFAULTS — an admin can override them at runtime via the /admin page.
